<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_secondary"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:title="@string/app_name"
        app:titleTextColor="@color/text_primary" />

    <com.linuxdroid.terminal.TerminalView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <LinearLayout
        android:id="@+id/extra_keys_bar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:padding="4dp"
        android:visibility="gone">

        <Button
            android:id="@+id/key_ctrl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CTRL"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_alt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ALT"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_esc"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ESC"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="TAB"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_arrow_up"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="↑"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_arrow_down"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="↓"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_arrow_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="←"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/key_arrow_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="→"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:padding="0dp" />

    </LinearLayout>

</LinearLayout>
